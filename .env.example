# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's already in .gitignore.

# --- Supabase (added when booking/admin features land) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email — booking confirmations) ---
RESEND_API_KEY=
# Verified sender address. Defaults to Resend's shared onboarding sender
# if unset; use a verified domain address in production.
RESEND_FROM_EMAIL=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
